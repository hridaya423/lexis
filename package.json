{
  "name": "smartterminal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lexis": "node lexis/src/index.mjs",
    "lexis:setup": "node lexis/src/index.mjs setup",
    "lexis:doctor": "node lexis/src/index.mjs doctor",
    "lexis:hooks:install": "node lexis/src/index.mjs hooks install",
    "lexis:hooks:uninstall": "node lexis/src/index.mjs hooks uninstall",
    "eval:smoke": "python3 eval/run_eval.py",
    "eval:hard": "python3 eval/run_eval.py --dataset eval/datasets/hard.jsonl",
    "eval:hard:quick": "python3 eval/run_eval.py --dataset eval/datasets/hard.jsonl --max-samples 12",
    "eval:terminal-bench": "bash eval/run_terminal_bench.sh",
    "eval:terminal-bench:hard": "bash eval/run_terminal_bench_hard.sh",
    "finetune:bootstrap": "python3 training/bootstrap_from_eval.py",
    "finetune:bootstrap:merge": "python3 training/merge_bootstrap.py",
    "finetune:build": "python3 training/build_sft_dataset.py",
    "finetune:build:mlx": "python3 training/build_mlx_dataset.py",
    "finetune:train": "python3 training/run_finetune.py",
    "finetune:train:smoke": "python3 training/run_finetune.py --model Qwen/Qwen2.5-0.5B-Instruct --train-file training/data/sft_chat.jsonl --output-dir training/artifacts/lexis-qlora-smoke --epochs 0.01 --batch-size 1 --grad-accum 1 --max-seq-len 256 --save-steps 1000",
    "finetune:merge": "python3 training/merge_adapter.py",
    "finetune:train:mlx": "python3 training/run_finetune_mlx.py",
    "finetune:train:mlx:smoke": "python3 training/run_finetune_mlx.py --model Qwen/Qwen2.5-0.5B-Instruct --data training/data/mlx_sft --adapter-path training/artifacts/mlx-qlora-smoke --iters 2 --batch-size 1 --learning-rate 2e-4 --max-seq-length 256 --grad-accumulation-steps 1 --steps-per-report 1 --steps-per-eval 2 --save-every 2",
    "finetune:merge:mlx": "python3 training/merge_adapter_mlx.py"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "framer-motion": "^12.38.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
